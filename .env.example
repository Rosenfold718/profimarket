# Database
# Set USE_TURSO=true to use Turso cloud database (recommended for production)
USE_TURSO=false
DATABASE_URL=file:./db/custom.db

# Turso Cloud Database (for Vercel production)
# Get these from https://turso.tech dashboard
TURSO_URL=libsql://your-project.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# JWT
JWT_SECRET=change-this-in-production