generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  role          String    @default("EXECUTOR") // CLIENT | EXECUTOR
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile         Profile?
  clientOrders    Order[]    @relation("ClientOrders")
  executorOrders  Order[]    @relation("ExecutorOrders")
  responses       Response[]
  sentMessages    Message[]  @relation("SentMessages")
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  company         String?
  position        String?
  experienceYears Int?
  specializations String   // JSON array string
  description     String?
  region          String?
  city            String?
  education       String?
  certificates    String?
  rating          Float    @default(0)
  completedOrders Int      @default(0)
  website         String?
  socialLinks     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id          String @id @default(cuid())
  name        String @unique
  slug        String @unique
  icon        String?
  description String?
  order       Int    @default(0)

  orders Order[]
}

model Order {
  id          String   @id @default(cuid())
  title       String
  description String
  categoryId  String?
  region      String?
  city        String?
  budgetFrom  Float?
  budgetTo    Float?
  deadline    DateTime?
  status      String   @default("OPEN")
  clientId    String
  executorId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client    User      @relation("ClientOrders", fields: [clientId], references: [id])
  executor  User?     @relation("ExecutorOrders", fields: [executorId], references: [id])
  category  Category? @relation(fields: [categoryId], references: [id])
  responses Response[]
  messages  Message[]
}

model Response {
  id              String   @id @default(cuid())
  orderId         String
  executorId      String
  message         String
  proposedBudget  Float?
  proposedDeadline DateTime?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  executor User  @relation(fields: [executorId], references: [id])
}

model Message {
  id        String   @id @default(cuid())
  orderId   String
  senderId  String
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender User  @relation("SentMessages", fields: [senderId], references: [id])

  @@index([orderId])
  @@index([senderId])
}
